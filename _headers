# Cache static assets aggressively
/assets/*
  Cache-Control: public, max-age=31536000, immutable

/assets/screenshots/*
  Cache-Control: public, max-age=31536000, immutable

# HTML - short cache with revalidation
/
  Cache-Control: public, max-age=3600, must-revalidate

/index.html
  Cache-Control: public, max-age=3600, must-revalidate

# SVG favicon
/assets/favicon.svg
  Cache-Control: public, max-age=31536000, immutable
